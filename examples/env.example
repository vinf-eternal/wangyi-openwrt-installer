# Example environment configuration for wangyi-openwrt-installer
#
# Copy this file to .env and customize the values
# Then source it before running: source .env

# istoreOS image URL (REQUIRED)
# ISTOREOS_IMG_URL="https://downloads.istoreos.com/istoreos-x86_64.img"
ISTOREOS_IMG_URL=""

# Target SD card device (optional, auto-detected if not set)
# ISTOREOS_SD_DEV="/dev/sdb"

# Enable dry-run mode (0 or 1)
# When set to 1, no actual writing will occur
ISTOREOS_DRY_RUN=0

# Verify image checksum after download (0 or 1)
ISTOREOS_VERIFY=0

# Skip confirmation prompt (USE WITH CAUTION!)
# ISTOREOS_NO_PROMPT=1

# Log file path
# ISTOREOS_LOG="/tmp/istoreos-install.log"
